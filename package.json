{
  "name": "boilerstone",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "Monorepo for Lonestone project",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "engines": {
    "node": "24.13.0",
    "pnpm": "10.28.2"
  },
  "scripts": {
    "rock": "tsx ./cli/setup.ts",
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "generate": "pnpm --filter=@boilerstone/openapi-generator run generate",
    "test": "pnpm -r test",
    "schematics:module": "pnpm --filter=@boilerstone/schematics run schematics:module",
    "docs-only": "pnpm --filter=@boilerstone/documentation run dev",
    "prepare": "husky"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "enquirer": "^2.4.1",

    "husky": "^9.1.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
