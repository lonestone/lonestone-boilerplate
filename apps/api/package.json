{
  "name": "@boilerstone/api",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "db:migration:init": "npx mikro-orm migration:create --initial",
    "db:migrate:create": "npx mikro-orm migration:create",
    "db:migrate:up": "npx mikro-orm migration:up",
    "db:migrate:down": "npx mikro-orm migration:down",
    "db:migrate:fresh": "npx mikro-orm migration:fresh",
    "db:migrate:seed": "npx mikro-orm migration:fresh --seed",
    "db:fresh": "npx mikro-orm schema:fresh --run",
    "db:fresh:seed": "npx mikro-orm schema:fresh --run --seed",
    "db:sync": "npx mikro-orm schema:update --run",
    "auth:generate": "auth generate --config src/modules/auth/auth.cli.ts --yes",
    "test": "cross-env NODE_ENV=test vitest run --config=vitest.config.ts",
    "test:watch": "cross-env NODE_ENV=test vitest --config=vitest.config.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/google": "^3.0.65",
    "@ai-sdk/mcp": "^1.0.37",
    "@ai-sdk/mistral": "^3.0.31",
    "@ai-sdk/openai": "^3.0.54",
    "@amplication/opentelemetry-nestjs": "6.0.0",
    "@dotenvx/dotenvx": "^1.64.0",
    "@faker-js/faker": "^10.4.0",
    "@langfuse/client": "^4.5.1",
    "@langfuse/otel": "^4.5.1",
    "@langfuse/tracing": "^4.5.1",
    "@lonestone/nzoth": "^1.2.0",
    "@mikro-orm/cli": "7.1.4",
    "@mikro-orm/core": "7.1.4",
    "@mikro-orm/decorators": "7.1.4",
    "@mikro-orm/migrations": "7.1.4",
    "@mikro-orm/nestjs": "7.0.2",
    "@mikro-orm/postgresql": "7.1.4",
    "@mikro-orm/seeder": "7.1.4",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "11.4.2",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@scalar/nestjs-api-reference": "^1.1.12",
    "@sentry/nestjs": "^10.51.0",
    "@sentry/opentelemetry": "^10.51.0",
    "@testcontainers/postgresql": "^11.14.0",
    "ai": "^6.0.170",
    "better-auth": "catalog:auth",
    "date-fns": "^4.1.0",
    "nestjs-pino": "4.6.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "slugify": "^1.6.9",
    "zod": "catalog:validation",
    "zod-openapi": "catalog:validation"
  },
  "devDependencies": {
    "@better-fetch/fetch": "1.1.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.32",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "catalog:build",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "auth": "1.6.9",
    "better-call": "1.3.5",
    "cross-env": "^10.1.0",
    "kysely": "0.28.16",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "test": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "catalog:build",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./src/modules/db/db.config.ts",
      "./dist/modules/db/db.config.js"
    ]
  }
}
