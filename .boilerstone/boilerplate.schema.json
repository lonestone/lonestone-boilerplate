{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Boilerplate Project State",
  "description": "Tracks a consumer project's relationship to the boilerplate for AI-assisted upgrades",
  "type": "object",
  "required": ["schemaVersion", "source", "trackedDomains", "intentions"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "description": "Schema version for future compatibility",
      "const": 1
    },
    "source": {
      "type": "object",
      "required": ["repository", "currentVersion"],
      "properties": {
        "repository": {
          "type": "string",
          "description": "Source boilerplate repository identifier",
          "examples": ["lonestone/lonestone-boilerplate"]
        },
        "remote": {
          "type": "string",
          "description": "Git remote URL used to fetch boilerplate release tags in consumer projects",
          "examples": ["https://github.com/lonestone/lonestone-boilerplate.git"]
        },
        "currentVersion": {
          "type": "string",
          "description": "Current tracked boilerplate version (SemVer)",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.5.0", "v1.5.0"]
        }
      },
      "additionalProperties": false
    },
    "trackedDomains": {
      "type": "array",
      "description": "Domains this project follows from the boilerplate",
      "items": {
        "type": "string",
        "enum": ["tooling", "api", "frontend", "ci", "docker-env", "monitoring", "email", "auth", "storage"]
      },
      "uniqueItems": true
    },
    "intentions": {
      "type": "object",
      "required": ["applied", "skipped"],
      "properties": {
        "applied": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "appliedAt"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Intention ID in format `vX.Y.Z/slug`",
                "pattern": "^v?\\d+\\.\\d+\\.\\d+/[a-z0-9-]+$"
              },
              "appliedAt": {
                "type": "string",
                "format": "date",
                "description": "Date the intention was applied (YYYY-MM-DD)"
              }
            },
            "additionalProperties": false
          }
        },
        "skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "reason"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Intention ID in format `vX.Y.Z/slug`",
                "pattern": "^v?\\d+\\.\\d+\\.\\d+/[a-z0-9-]+$"
              },
              "reason": {
                "type": "string",
                "description": "Reason for skipping this intention",
                "minLength": 10
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
